# Database
DATABASE_URL=postgresql://postgres:your_password@your-rds-endpoint.region.rds.amazonaws.com:5432/exiuscart

# JWT Secret
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=ExiusCart API
DEBUG=True

# SMTP (AWS SES) — required for OTP and welcome emails
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-ses-smtp-username
SMTP_PASSWORD=your-ses-smtp-password
SMTP_FROM_NOREPLY=noreply@exiuscart.com
SMTP_FROM_BILLING=billing@exiuscart.com
SMTP_FROM_NAME=ExiusCart

# Cloudflare R2 image storage (required — no local disk fallback)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=exiuscart-image
R2_PUBLIC_URL=https://your-custom-domain.com

# Partner integrations
THEDERSI_PARTNER_KEY=change-this-to-a-strong-secret-key
THEDERSI_HMAC_SECRET=get-this-from-thedersi-team
THEDERSI_WEBHOOK_URL=https://thedersi.lk/api/exiuscart/webhook

# Lemon Squeezy payment gateway (direct ExiusCart Starter/Premium billing)
LEMONSQUEEZY_API_KEY=get-this-from-lemonsqueezy-dashboard
LEMONSQUEEZY_STORE_ID=get-this-from-lemonsqueezy-dashboard
LEMONSQUEEZY_WEBHOOK_SECRET=get-this-from-lemonsqueezy-dashboard
# Create one Product with 4 Variants in Lemon Squeezy (Starter/Premium x Monthly/Yearly), then paste their variant IDs here
LEMONSQUEEZY_STARTER_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_STARTER_YEARLY_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_YEARLY_VARIANT_ID=

# Daraz Open Platform (get App Key/Secret from open.daraz.com after app approval)
# Authorize URL is per-country (see DARAZ_COUNTRY_AUTHORIZE_URLS in daraz.py) —
# no env var needed for it.
DARAZ_APP_KEY=get-this-from-open.daraz.com
DARAZ_APP_SECRET=get-this-from-open.daraz.com
DARAZ_API_BASE_URL=https://api.daraz.com/rest
