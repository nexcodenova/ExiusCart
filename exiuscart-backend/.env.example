# Database
DATABASE_URL=postgresql://postgres:your_password@your-rds-endpoint.region.rds.amazonaws.com:5432/exiuscart

# JWT Secret
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=ExiusCart API
DEBUG=True

# SMTP (AWS SES) — required for OTP and welcome emails
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-ses-smtp-username
SMTP_PASSWORD=your-ses-smtp-password
SMTP_FROM_NOREPLY=noreply@exiuscart.com
SMTP_FROM_BILLING=billing@exiuscart.com
SMTP_FROM_NAME=ExiusCart

# Cloudflare R2 image storage (required — no local disk fallback)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=exiuscart-images
R2_PUBLIC_URL=https://your-custom-domain.com

# Partner integrations
THEDERSI_PARTNER_KEY=change-this-to-a-strong-secret-key
THEDERSI_HMAC_SECRET=get-this-from-thedersi-team
THEDERSI_WEBHOOK_URL=https://thedersi.lk/api/exiuscart/webhook
