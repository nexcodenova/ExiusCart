ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=ExiusCart API
DEBUG=True

# Partner integrations
THEDERSI_PARTNER_KEY=change-this-to-a-strong-secret-key
THEDERSI_HMAC_SECRET=get-this-from-thedersi-team
